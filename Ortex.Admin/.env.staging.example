# ── STAGING environment (hosted on Vercel) ────────────────────────────────
# Loaded by:  npm run dev:staging   and   npm run build:staging
# Copy to `.env.staging` for local staging builds. On Vercel, DO NOT commit this
# file — set the same VITE_ vars in the Vercel project's Environment Variables
# (they are injected at build time and override any file here).
#
# These MUST point at the dedicated STAGING Supabase project, never production.
VITE_SUPABASE_URL=https://YOUR-STAGING-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-public-key

# Shown as a badge in the Admin sidebar so no one confuses staging with prod.
VITE_ENV_LABEL=Staging

# Optional: deploy hook for the STAGING marketing site (leave blank to disable).
VITE_DEPLOY_HOOK_URL=

# Reminder: the AI Edge Functions need GEMINI_API_KEY set as a secret on the
# STAGING Supabase project (not a VITE_ var):
#   supabase functions deploy <fn> --project-ref YOUR-STAGING-ref
#   supabase secrets set GEMINI_API_KEY=... --project-ref YOUR-STAGING-ref
