# ── PRODUCTION environment (hosted on a Hostinger subdomain) ───────────────
# Loaded by:  npm run build  (default)  and  npm run build:production
# Copy to `.env.production` on the machine that builds the production bundle,
# fill in the PRODUCTION Supabase project's values, run `npm run build`, then
# upload the contents of dist/ to the Hostinger subdomain (e.g. admin.ortexindustries.in).
#
# These MUST point at the PRODUCTION Supabase project (the one with real
# invoices / payments / customers).
VITE_SUPABASE_URL=https://YOUR-PRODUCTION-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-public-key

# Leave blank in production so no environment badge shows.
VITE_ENV_LABEL=

# Optional: deploy hook for the PRODUCTION marketing site (leave blank to disable).
VITE_DEPLOY_HOOK_URL=

# Reminder: GEMINI_API_KEY is a SECRET on the PRODUCTION Supabase project, set
# via `supabase secrets set` on that project's Edge Functions (never a VITE_ var).
